{
  "description": "Balanced, non-blocking lifecycle hooks for Aster.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const c=require('child_process'),p=require('path');let r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(!r){let g='';try{g=c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8',stdio:['ignore','pipe','ignore']}).trim()}catch{}r=p.join(g||process.cwd(),'.aster')}require(p.join(r,'scripts','aster-hooks','runner.js')).main(process.argv[1])}catch{}\" SessionStart",
            "timeout": 10,
            "statusMessage": "Loading approved project memory"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const c=require('child_process'),p=require('path');let r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(!r){let g='';try{g=c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8',stdio:['ignore','pipe','ignore']}).trim()}catch{}r=p.join(g||process.cwd(),'.aster')}require(p.join(r,'scripts','aster-hooks','runner.js')).main(process.argv[1])}catch{}\" PreCompact",
            "timeout": 10,
            "statusMessage": "Saving a bounded task snapshot"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const c=require('child_process'),p=require('path');let r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(!r){let g='';try{g=c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8',stdio:['ignore','pipe','ignore']}).trim()}catch{}r=p.join(g||process.cwd(),'.aster')}require(p.join(r,'scripts','aster-hooks','runner.js')).main(process.argv[1])}catch{}\" PreToolUse",
            "timeout": 10,
            "statusMessage": "Tracking project context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const c=require('child_process'),p=require('path');let r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(!r){let g='';try{g=c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8',stdio:['ignore','pipe','ignore']}).trim()}catch{}r=p.join(g||process.cwd(),'.aster')}require(p.join(r,'scripts','aster-hooks','runner.js')).main(process.argv[1])}catch{}\" PostToolUse",
            "timeout": 10,
            "statusMessage": "Recording tool activity"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const c=require('child_process'),p=require('path');let r=process.env.PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT;if(!r){let g='';try{g=c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8',stdio:['ignore','pipe','ignore']}).trim()}catch{}r=p.join(g||process.cwd(),'.aster')}require(p.join(r,'scripts','aster-hooks','runner.js')).main(process.argv[1])}catch{}\" Stop",
            "timeout": 10,
            "statusMessage": "Saving session state"
          }
        ]
      }
    ]
  }
}
